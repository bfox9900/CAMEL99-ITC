

INCLUDE DSK1.ELAPSE
INCLUDE DSK1.3RD4TH
INCLUDE DSK1.TAILCALL

\ 1 iteration
\ without tailcall 45.4
\ with tailcall    44.83

DECIMAL
 : 3DUP 3RD 3RD 3RD ;

 : TAK ( X Y Z -- T )
   OVER 4TH 1- > NEGATE IF NIP NIP EXIT THEN
   3DUP ROT  1- -ROT RECURSE >R
   3DUP SWAP 1- -ROT SWAP RECURSE >R
             1- -ROT RECURSE
   R> SWAP R> -ROT RECURSE -;

 : TAKBENCH ( -- )
   0 1 0 DO   DROP 18 12 6 TAK   LOOP DROP ;

: 200X   200 0 DO  TAKBENCH  LOOP ;

\ ELAPSE 200X
